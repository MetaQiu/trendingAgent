# PostgreSQL 数据库连接，生产环境建议使用 Neon / Supabase / Vercel Postgres 等外部 Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Cron 接口鉴权密钥，用于 /api/cron/update-trending
CRON_SECRET="change-me-to-a-long-random-secret"

# GitHub Trending 抓取配置
GITHUB_TRENDING_LANGUAGES="all"
GITHUB_TRENDING_SINCE="daily"

# LLM 配置：默认使用 Anthropic Claude
LLM_PROVIDER="anthropic"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-6"

# 可选：OpenAI-compatible Provider
# 使用时设置 LLM_PROVIDER="openai-compatible"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL=""
